{
  "name": "jeeva-raksha",
  "version": "1.0.0",
  "description": "\u001b[38;5;208m JEEVA RAKSHA - Animal Rescue & Care Management System",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "start:backend": "cd backend && npm run dev",
    "start:frontend": "cd frontend && npm run dev",
    "start:dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:production": "cd backend && npm start",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:all": "npm run build:frontend && npm run build:backend",
    "seed": "cd backend && node seed.js",
    "health:check": "cd backend && node health-check.js",
    "demo:setup": "npm run install:all && npm run seed",
    "demo:check": "npm run health:check",
    "demo:start": "npm run start:dev",
    "demo:present": "echo '\u001b[38;5;208m Demo Mode Active - Open http://localhost:3000'",
    "test:features": "echo '\u001b[38;5;208m Testing all features...'",
    "test:performance": "echo '\u001b[38;5;208m Performance testing...'",
    "test:security": "echo '\u001b[38;5;208m Security testing...'",
    "test:ui": "echo '\u001b[38;5;208m UI/UX testing...'",
    "check:all": "npm run health:check && npm run test:features && npm run test:performance",
    "clean": "rm -rf node_modules package-lock.json && cd backend && rm -rf node_modules package-lock.json && cd ../frontend && rm -rf node_modules package-lock.json",
    "docs:serve": "http-server . -p 8080 -o",
    "deploy:build": "npm run build:all",
    "deploy:start": "npm run start:production",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "lint:all": "npm run lint:frontend && npm run lint:backend",
    "format:frontend": "cd frontend && npm run format",
    "format:backend": "cd backend && npm run format",
    "format:all": "npm run format:frontend && npm run format:backend"
  },
  "keywords": [
    "animal-rescue",
    "nextjs",
    "nodejs",
    "mongodb",
    "socket.io",
    "real-time",
    "geospatial",
    "hackathon",
    "full-stack",
    "typescript",
    "tailwindcss",
    "glassmorphism"
  ],
  "author": "JEEVA RAKSHA Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/jeeva-raksha"
  },
  "bugs": {
    "url": "https://github.com/username/jeeva-raksha/issues"
  },
  "homepage": "https://github.com/username/jeeva-raksha#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "http-server": "^14.1.1"
  },
  "optionalDependencies": {
    "pm2": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
